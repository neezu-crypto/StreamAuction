rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // system: 누구나 읽기, 쓰기 차단
    match /system/{document} {
      allow read: if true;
      allow write: if false;
    }

    // users: 본인만 읽기, 쓰기는 Cloud Functions만
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow write: if false;
    }

    // users/{uid}/balanceHistory: 본인만 읽기/생성, 수정·삭제 불가
    match /users/{userId}/balanceHistory/{docId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId)
        && request.resource.data.balance is number
        && request.resource.data.balance >= 0
        && request.resource.data.delta is number;
      allow update, delete: if false;
    }

    // listings: 누구나 읽기, 쓰기는 Cloud Functions만
    match /listings/{listingId} {
      allow read: if true;
      allow write: if false;
    }

    // auctionHistory: 누구나 읽기, 쓰기는 Cloud Functions만
    // 경매 완료 기록 (히스토리 BM 용)
    match /auctionHistory/{auctionId} {
      allow read: if true;
      allow write: if false;
    }

    // reports: 신고자 본인만 읽기, 쓰기는 Cloud Functions만
    match /reports/{reportId} {
      allow read: if isAuthenticated()
        && resource.data.reporterId == request.auth.uid;
      allow write: if false;
    }

    // auctionRequests: 요청자 또는 보유자(ownerId)만 읽기, 쓰기는 Cloud Functions만
    match /auctionRequests/{requestId} {
      allow read: if isAuthenticated()
        && (resource.data.requesterId == request.auth.uid
            || resource.data.ownerId == request.auth.uid);
      allow write: if false;
    }

    // ads: 누구나 읽기 (활성 광고 목록 표시), 쓰기는 Cloud Functions만
    match /ads/{adId} {
      allow read: if true;
      allow write: if false;
    }

    // users/{uid}/adClaims: 본인만 읽기, 쓰기는 Cloud Functions만
    match /users/{userId}/adClaims/{adId} {
      allow read: if isOwner(userId);
      allow write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
